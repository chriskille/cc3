# ⚡ COMMAND CENTER v2 — copy this to .env and fill in all values

# Supabase (https://supabase.com → project → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Twilio SMS (https://console.twilio.com) — SERVER ONLY
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Resend Email (https://resend.com) — SERVER ONLY
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@eostaff.com
RESEND_FROM_NAME=EOStaff Command Center

# App
VITE_APP_NAME=Command Center
VITE_APP_URL=http://localhost:3000
SERVER_PORT=3001
